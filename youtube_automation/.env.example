# API нӮӨ м„Өм • нҢҢмқј
# мқҙ нҢҢмқјмқ„ .envлЎң ліөмӮ¬ нӣ„ нӮӨлҘј мһ…л Ҙн•ҳм„ёмҡ”
# cp .env.example .env

# Anthropic (Claude) - лҢҖліё мғқм„ұ
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs - TTS мқҢм„ұ мғқм„ұ
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...   # н•ңкөӯм–ҙ ліҙмқҙмҠӨ ID (ElevenLabsм—җм„ң нҷ•мқё)

# OpenAI - DALL-E мқҙлҜём§Җ мғқм„ұ (м„ нғқ)
OPENAI_API_KEY=sk-...

# YouTube - client_secrets.json нҢҢмқј кІҪлЎң (Google Cloud Consoleм—җм„ң лӢӨмҡҙлЎңл“ң)
# YOUTUBE_CLIENT_SECRETS=client_secrets.json
